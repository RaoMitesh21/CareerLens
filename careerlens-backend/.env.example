# CareerLens Backend Configuration
# Copy this file to .env and fill in your values

# ============================================
# DATABASE
# ============================================
DB_USER=root
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=3306
DB_NAME=careerlens

# ============================================
# SECURITY & JWT
# ============================================
SECRET_KEY=your-super-secret-key-change-in-production-use-strong-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# EMAIL (SMTP)
# ============================================
# For Gmail: Enable "App passwords" and use that password
# https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-specific-password

# Alternative: Use other SMTP services
# SMTP_SERVER=smtp.mailgun.org
# SMTP_PORT=587
# SENDER_EMAIL=postmaster@your-domain.com
# SENDER_PASSWORD=your-mailgun-password

# ============================================
# API CONFIGURATION
# ============================================
APP_ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]

# ============================================
# AWS (Optional - for file uploads)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
